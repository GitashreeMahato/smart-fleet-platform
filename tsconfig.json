{
  // Visit https://aka.ms/tsconfig to read more about this file
  
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",

    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "lib": ["esnext"],
    "types": ["node"],

    "sourceMap": true,
    "declaration": false,

    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]

  }

